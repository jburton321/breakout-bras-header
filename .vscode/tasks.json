{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open 127.0.0.1:3000 in Simple Browser",
      "type": "shell",
      "command": "echo ${input:openSimpleBrowser}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "echo": false,
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Dev: LAN (all interfaces, port 3000)",
      "type": "shell",
      "command": "npm run dev:lan",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ],
  "inputs": [
    {
      "id": "openSimpleBrowser",
      "type": "command",
      "command": "simpleBrowser.api.open",
      "args": ["http://127.0.0.1:3000/"]
    }
  ]
}
